# Sample .env file for Medical AI Assistant
# Rename this file to .env to use it

# Add your Hugging Face API key here (if available)
# You can get a free key at https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_key_here

# Azure Speech Service credentials
# You can get these from the Azure portal: https://portal.azure.com/
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus

# Speech recognition timeout in seconds
# Used as a fallback when Azure Speech fails
SPEECH_TIMEOUT=5 