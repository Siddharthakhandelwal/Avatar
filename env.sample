# Dr. Maya Medical Assistant - Environment Variables

# -----------------------------------------------------------------------------
# API Keys for External Services
# -----------------------------------------------------------------------------

# OpenAI API Key (required for natural language understanding)
# Get one at: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Azure Speech Service (for voice capabilities)
# Create a Speech resource at: https://portal.azure.com
# These are optional - text-to-speech will use local fallback if not provided
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# Speech timeout in seconds (how long to listen for voice input)
SPEECH_TIMEOUT=5

# Default settings for the medical assistant
ASSISTANT_NAME=Dr. Maya
HOSPITAL_NAME=Wellness Care Center

# -----------------------------------------------------------------------------
# Database Settings
# -----------------------------------------------------------------------------
# By default, the application stores data in JSON files in the application directory
# You can optionally configure different paths for storage:

# APPOINTMENTS_FILE=./data/appointments.json
# MEDICATIONS_FILE=./data/medications.json
# PATIENT_VITALS_FILE=./data/patient_vitals.json 